<Feeds>
    <Feed FeedName="C:\\Users\\yogesh.patil\\Desktop\\FeedParser\\testdata.csv">
        <properties delimiter ="," skipHeader="3" skipFooter="0" feedType="CSV"/>
        <columns>
            <column index = "1" DataType="str">Account</column>
            <column index = "2" DataType="str">DCIP</column>
            <column index = "3" DataType="float">Amount</column>
            <column index = "4" DataType="str">TranDate</column>
        </columns>
        <staticColumns>
            <column name="cob_date">
                <rule><![CDATA[cob_date[11:21]]]></rule>
                <filter resultIndex="0"><![CDATA[cob_date[:3] == "cob"]]></filter><!--rowNumber="1" -->
            </column>
        </staticColumns>
        <discards>
            <!--<rule><![CDATA[DCIP.upper() == "CREDIT"]]></rule>-->
            <rule></rule>
        </discards>
        
        <Enrichments>
            <Enrichment ColumnName="DCIP">
                <rule><![CDATA[DCIP.upper()]]></rule>
                <filter></filter>
            </Enrichment>
            <Enrichment ColumnName="OriginalAmount" dataType="str">
                <rule><![CDATA[Amount/100]]></rule>
            </Enrichment>
<!--
            <Enrichment ColumnName="Amount">
                <rule><![CDATA[Amount/100]]></rule>
                <filter><![CDATA[Amount>1000]]></filter>
            </Enrichment>
            -->
            <Enrichment ColumnName="DCIP">
                <rule><![CDATA["CREDIT"]]></rule>
                <filter>DCIP == "CR"</filter>
            </Enrichment>
            <GroupEnrichment ColumnName="Amount">
                <rule><![CDATA[max(Amount)]]></rule>
                <!--<groupBy>DCIP</groupBy>-->
                <filter><![CDATA[Amount<5000]]></filter>
            </GroupEnrichment>

            <Enrichment ColumnName="COBDATE">
                <rule><![CDATA[cob_date]]></rule>
            </Enrichment>
        </Enrichments>

        <SingleStageDiscard>
            <rule><![CDATA[]]></rule>
        </SingleStageDiscard>
        <outputs>
            <output FeedName ="CRDATA" feedType="DATAFRAME" >
                <columns>
                    <column>Account</column>
                    <column>DCIP</column>
                    <column>Amount</column>
                    <column>COBDATE</column>
                    <column>TranDate</column>
                </columns>
                <filter>DCIP == 'CREDIT'</filter>
            </output>
            <output FeedName ="C:\\Users\\yogesh.patil\\Desktop\\FeedParser\\ResultDE.csv" delimiter ="," feedType="CSV" header="True">
                <columns>
                    <column>Account</column>
                    <column>DCIP</column>
                    <column>Amount</column>
                    <column>COBDATE</column>
                    <column>TranDate</column>
                </columns>
                <filter>DCIP == 'DEBIT'</filter>
            </output>
        </outputs>

    </Feed>


    <Feed FeedName="C:\\Users\\yogesh.patil\\Desktop\\FeedParser\\fixedWidthData.dat">
        <properties delimiter ="," skipHeader="0" skipFooter="0" feedType="FIXWIDTH"/>
        <columns>
            <column index = "(0,14)" DataType="str">Account</column>
            <column index = "(15,28)" DataType="str">Name</column>
            <column index = "(28,40)" DataType="str">Trade</column>
        </columns>
        <!--<staticColumns>-->
           <!-- <column name="cob_date">
                <rule><![CDATA[cob_date[11:21]]]></rule>
                <filter resultIndex="0"><![CDATA[cob_date[:3] == "cob"]]></filter>
            </column>--><!-- Filter properties : rowNumber="1" -->
        <!--</staticColumns>-->
        <discards>
            <rule><![CDATA[Trade.upper() == "CREDIT"]]></rule>
            <rule></rule>
        </discards>
        
        <Enrichments>
            <Enrichment ColumnName="Trade">
                <rule><![CDATA[Trade.upper()]]></rule>
                <filter></filter>
            </Enrichment>
           <JoinEnrichment DataFrame="CRDATA">
                <how>leftt</how>
                <on>Account</on>
            </JoinEnrichment>

        </Enrichments>

        <SingleStageDiscard>
            <rule><![CDATA[]]></rule>
        </SingleStageDiscard>
         <outputs>
           
            <output FeedName ="C:\\Users\\yogesh.patil\\Desktop\\FeedParser\\JoinData.csv" delimiter ="," feedType="CSV" header="True">
                <columns>
                    <column>Account</column>
                    <column>DCIP</column>
                    <column>Amount</column>
                    <column>Name</column>
                    <column>Trade</column>
                    <column>COBDATE</column>
                </columns>
                
            </output>
        </outputs>

    </Feed>


</Feeds>
